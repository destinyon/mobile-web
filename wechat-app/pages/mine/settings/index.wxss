.brand-strip {
  display: flex;
  align-items: center;
  height: 64rpx;
  margin-bottom: 18rpx;
}

.back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  color: #172117;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1;
}

.brand-title-mini {
  flex: 1;
  padding-right: 48rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 800;
}

.about-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 26rpx;
  background: #fffdf4;
}

.mascot {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 104rpx;
  width: 104rpx;
  height: 104rpx;
  border: 3rpx solid #172117;
  border-radius: 50%;
  background: #ffe59a;
  color: #172117;
  font-size: 42rpx;
  font-weight: 900;
  box-shadow: 5rpx 5rpx 0 #172117;
}

.about-main {
  min-width: 0;
}

.about-title {
  color: #172117;
  font-size: 34rpx;
  font-weight: 900;
}

.about-desc {
  margin-top: 10rpx;
  color: #566250;
  font-size: 25rpx;
  line-height: 1.55;
}

.intro-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.intro-item {
  display: flex;
  gap: 18rpx;
  padding: 22rpx;
  border: 2rpx solid #d6dfcf;
  border-radius: 16rpx;
  background: #ffffff;
}

.intro-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 54rpx;
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: #e4f8ce;
  color: #2b7f56;
  font-size: 28rpx;
  font-weight: 900;
}

.intro-title {
  color: #172117;
  font-size: 28rpx;
  font-weight: 900;
}

.intro-desc {
  margin-top: 6rpx;
  color: #65705f;
  font-size: 24rpx;
  line-height: 1.5;
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 82rpx;
  margin-top: 30rpx;
  border: 2rpx solid #172117;
  border-radius: 16rpx;
  background: #ffe4df;
  color: #c74632;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: 6rpx 6rpx 0 #172117;
}

.secondary-btn {
  margin-top: 30rpx;
}
