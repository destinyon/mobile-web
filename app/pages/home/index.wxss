.publish-link {
  min-width: 160rpx;
  min-height: 54rpx;
  border: 2rpx solid #172117;
  border-radius: 999rpx;
  background: #baf279;
  color: #172117;
  font-size: 24rpx;
  font-weight: 800;
}

.search-entry {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 22rpx;
  padding: 18rpx 22rpx;
  border: 2rpx solid #172117;
  border-radius: 16rpx;
  background: #ffffff;
  color: #65705f;
  font-size: 26rpx;
}

.search-icon {
  width: 34rpx;
  color: #172117;
  font-size: 34rpx;
  line-height: 1;
}

.banner {
  height: 268rpx;
  margin-top: 20rpx;
  border: 2rpx solid #172117;
  border-radius: 8rpx;
  overflow: hidden;
  background: #dff5c9;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.category-row {
  width: 100%;
  margin-top: 24rpx;
  white-space: nowrap;
}

.category {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  min-height: 54rpx;
  margin-right: 10rpx;
  padding: 0 28rpx;
  border: 2rpx solid #172117;
  border-radius: 18rpx;
  background: #ffffff;
  color: #172117;
  font-size: 24rpx;
}

.category.active {
  background: #172117;
  color: #ffffff;
}

.news-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.load-more {
  padding: 30rpx 0 8rpx;
  text-align: center;
}
