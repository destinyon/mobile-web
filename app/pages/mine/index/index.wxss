.mine-brand {
  margin-bottom: 18rpx;
}

.profile {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx;
  border-radius: 6rpx;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 108rpx;
  width: 108rpx;
  height: 108rpx;
  border: 2rpx solid #172117;
  border-radius: 50%;
  background: #dff5c9;
}

.avatar-placeholder {
  color: #172117;
  font-size: 46rpx;
  font-weight: 900;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.name {
  margin-bottom: 10rpx;
  color: #172117;
  font-size: 32rpx;
  font-weight: 900;
}

.login-mini {
  min-width: 110rpx;
  min-height: 58rpx;
  border: 2rpx solid #172117;
  border-radius: 999rpx;
  background: #baf279;
  color: #172117;
  font-size: 24rpx;
  font-weight: 800;
}

.tool-list {
  border: 2rpx solid #172117;
  border-radius: 6rpx;
  overflow: hidden;
  background: #ffffff;
}

.tool-item {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  padding: 0 18rpx;
  border: 2rpx solid #172117;
  border-width: 0 0 2rpx;
  background: #ffffff;
  color: #172117;
  font-size: 27rpx;
  font-weight: 800;
}

.tool-item:last-child {
  border-bottom: 0;
}

.tool-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  margin-right: 18rpx;
  border: 2rpx solid #172117;
  border-radius: 8rpx;
  background: #f4fee9;
  font-size: 23rpx;
}

.tool-text {
  flex: 1;
}

.tool-arrow {
  color: #172117;
  font-size: 44rpx;
  line-height: 1;
}
