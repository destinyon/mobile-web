@import "./styles/theme.wxss";

page {
  min-height: 100%;
  background: #f4fee9;
  color: #172117;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

view,
text,
input,
textarea,
button {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  line-height: 1.4;
}

button::after {
  border: 0;
}
