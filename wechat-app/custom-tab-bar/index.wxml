<view wx:if="{{!hidden}}" class="tabbar">
  <view wx:for="{{list}}" wx:key="pagePath" class="tab-item {{selected === index ? 'active' : ''}} {{item.center ? 'center' : ''}}" data-index="{{index}}" bindtap="switchTab">
    <view class="tab-icon">{{selected === index ? item.activeIcon : item.icon}}</view>
    <view class="tab-text">{{item.text}}</view>
  </view>
</view>
