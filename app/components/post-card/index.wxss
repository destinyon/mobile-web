.post-card {
  padding: 20rpx;
  border: 2rpx solid #172117;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 6rpx 6rpx 0 rgba(23, 33, 23, 0.16);
}

.post-head,
.meta {
  display: flex;
  align-items: center;
  gap: 18rpx;
  color: #65705f;
  font-size: 23rpx;
}

.topic {
  padding: 5rpx 14rpx;
  border: 2rpx solid #172117;
  border-radius: 999rpx;
  background: #baf279;
  color: #172117;
  font-weight: 800;
}

.status {
  margin-left: auto;
}

.title {
  margin-top: 14rpx;
  color: #172117;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.35;
}

.content {
  display: -webkit-box;
  margin-top: 10rpx;
  overflow: hidden;
  color: #3d493a;
  font-size: 26rpx;
  line-height: 1.55;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.image-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  margin-top: 14rpx;
}

.thumb {
  width: 100%;
  height: 132rpx;
  border: 2rpx solid #172117;
  border-radius: 6rpx;
}

.meta {
  margin-top: 16rpx;
}
