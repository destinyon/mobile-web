@import "../../news/detail/index.wxss";

.post {
  padding: 20rpx;
  border-radius: 8rpx;
}

.topic {
  display: inline-flex;
  min-height: 48rpx;
  padding: 0 18rpx;
  align-items: center;
  border: 2rpx solid #172117;
  border-radius: 8rpx;
  background: #baf279;
  color: #172117;
  font-size: 24rpx;
  font-weight: 800;
}

.edit-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  color: #172117;
  font-size: 36rpx;
  font-weight: 900;
}

.author-row,
.comment-head {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}

.avatar,
.comment-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #172117;
  border-radius: 50%;
  background: #dff5c9;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
}

.comment-avatar {
  flex: 0 0 64rpx;
  width: 64rpx;
  height: 64rpx;
}

.avatar-placeholder {
  color: #172117;
  font-size: 28rpx;
  font-weight: 900;
}

.author-main,
.comment-main {
  flex: 1;
  min-width: 0;
}

.author-name {
  color: #172117;
  font-size: 27rpx;
  font-weight: 900;
}

.cover-image {
  width: 100%;
  height: 286rpx;
  margin-top: 18rpx;
  border: 2rpx solid #172117;
  border-radius: 8rpx;
}

.image-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.post-image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 18rpx;
}

.post-image {
  width: 100%;
  height: 206rpx;
  border: 2rpx solid #172117;
  border-radius: 8rpx;
}

.reply-panel {
  margin-top: 16rpx;
  padding: 16rpx;
  border: 2rpx solid #172117;
  border-radius: 8rpx;
  background: #fafff3;
}

.reply-tip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
  color: #65705f;
  font-size: 24rpx;
}

.comment-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #172117;
  font-size: 26rpx;
  font-weight: 800;
}

.reply-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin: 12rpx 0 0 78rpx;
  padding: 12rpx;
  border-radius: 8rpx;
  background: #f4fee9;
}

.reply-item {
  color: #3d493a;
  font-size: 25rpx;
  line-height: 1.5;
}

.reply-name {
  color: #172117;
  font-weight: 800;
}
