<view class="page-shell home-shell">
  <view class="brand-bar">
    <view class="brand-title"><text class="brand-mark">羽</text>羽球在线</view>
  </view>

  <view class="search-entry" bindtap="goSearch">
    <text class="search-icon">⌕</text>
    <text>搜索外部新闻、赛事讨论、社区交流、羽球装备</text>
  </view>

  <swiper wx:if="{{banners.length}}" class="banner" indicator-dots autoplay circular>
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <view class="banner-item" bindtap="onBannerTap" data-item="{{item}}">
        <image class="banner-img" src="{{item.imageUrl}}" mode="aspectFill"></image>
        <view class="banner-caption">{{item.title}}</view>
      </view>
    </swiper-item>
  </swiper>

  <view class="category-row">
    <view wx:for="{{filters}}" wx:key="type" class="category {{activeFilter === item.type ? 'active' : ''}}" bindtap="selectFilter" data-type="{{item.type}}">
      {{item.label}}
    </view>
  </view>

  <view class="section-title">
    <text>首页内容</text>
    <text class="muted">{{total ? total + ' 条' : ''}}</text>
  </view>

  <view wx:if="{{loading}}" class="state-box">正在加载内容...</view>
  <view wx:elif="{{error}}" class="state-box" bindtap="loadAll">{{error}}，点击重试</view>
  <view wx:elif="{{!feedItems.length}}" class="state-box">暂无内容，切换分类看看</view>
  <view wx:else class="post-list">
    <post-card wx:for="{{feedItems}}" wx:key="feedKey" item="{{item}}"></post-card>
  </view>

  <view wx:if="{{feedItems.length}}" class="load-more muted">{{hasMore ? '上拉加载更多' : '没有更多了'}}</view>
</view>
