<view class="page-shell">
  <view class="brand-strip">
    <view class="back" bindtap="goBack">‹</view>
    <text class="brand-title-mini">我的收藏</text>
  </view>
  <view class="section-title">我的收藏</view>
  <view wx:if="{{loading}}" class="state-box">正在加载...</view>
  <view wx:elif="{{error}}" class="state-box" bindtap="load">{{error}}，点击重试</view>
  <view wx:elif="{{!items.length}}" class="state-box">还没有收藏内容</view>
  <view wx:else class="favorite-list">
    <post-card wx:for="{{items}}" wx:key="feedKey" item="{{item}}"></post-card>
  </view>
  <auth-popup visible="{{showAuth}}" bind:cancel="hideAuth" bind:success="afterLogin"></auth-popup>
</view>
