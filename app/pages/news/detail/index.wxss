.cover {
  width: 100%;
  height: 360rpx;
  border: 2rpx solid #172117;
  border-radius: 18rpx;
  background: #dff5c9;
}

.article {
  margin-top: 24rpx;
  padding: 30rpx 28rpx;
  border: 2rpx solid #172117;
  border-radius: 18rpx;
  background: #ffffff;
}

.title {
  color: #172117;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.35;
}

.meta {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin: 18rpx 0 28rpx;
  color: #65705f;
  font-size: 24rpx;
}

.content {
  color: #283227;
  font-size: 30rpx;
  line-height: 1.85;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 24rpx;
}

.action-btn {
  min-height: 76rpx;
  border: 2rpx solid #172117;
  border-radius: 16rpx;
  background: #ffffff;
  color: #172117;
  font-size: 28rpx;
  font-weight: 800;
}

.comment-box {
  margin-top: 28rpx;
  padding: 24rpx;
  border: 2rpx solid #172117;
  border-radius: 18rpx;
  background: #ffffff;
}

.comment-input {
  width: 100%;
  min-height: 150rpx;
  padding: 18rpx;
  border: 2rpx solid #d6dfcf;
  border-radius: 14rpx;
  font-size: 28rpx;
}

.comment-box .primary-btn {
  margin-top: 18rpx;
}

.comments {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.comment-item {
  padding: 22rpx;
  border: 2rpx solid #172117;
  border-radius: 16rpx;
  background: #ffffff;
}

.comment-head {
  color: #172117;
  font-size: 26rpx;
  font-weight: 800;
}

.comment-content {
  margin-top: 10rpx;
  color: #3d493a;
  font-size: 27rpx;
  line-height: 1.6;
}
