<view class="page-shell detail-shell">
  <view wx:if="{{loading}}" class="state-box">正在加载帖子...</view>
  <view wx:elif="{{error}}" class="state-box" bindtap="loadDetail">{{error}}，点击重试</view>
  <view wx:else>
    <view class="brand-strip">
      <view class="back" bindtap="goBack">‹</view>
      <text class="brand-title-mini">帖子详情</text>
      <view wx:if="{{isOwner}}" class="edit-action" bindtap="goEdit">✎</view>
    </view>

    <view class="post card">
      <view class="topic">{{detail.topicName || '球友投稿'}}</view>
      <view class="title">{{detail.title}}</view>
      <view class="author-row">
        <image wx:if="{{detail.avatarUrl}}" class="avatar" src="{{detail.avatarUrl}}" mode="aspectFill"></image>
        <view wx:else class="avatar avatar-placeholder">羽</view>
        <view class="author-main">
          <view class="author-name">{{detail.nickname || '球友'}}</view>
          <view class="meta">
            <text>◉ {{detail.viewCount || 0}}</text>
            <text>☰ {{detail.commentCount || 0}}</text>
            <text>赞 {{detail.likeCount || 0}}</text>
            <text>{{detail.updatedAt || ''}}</text>
          </view>
        </view>
      </view>
      <image wx:if="{{detail.coverUrl}}" class="cover-image" src="{{detail.coverUrl}}" mode="aspectFill"></image>
      <view class="content">{{detail.content}}</view>
      <view wx:if="{{detail.images && detail.images.length}}" class="post-image-grid">
        <image wx:for="{{detail.images}}" wx:key="*this" class="post-image" src="{{item}}" mode="aspectFill"></image>
      </view>
    </view>

    <view wx:if="{{replyTarget.id}}" class="reply-panel">
      <view class="reply-tip">
        <text>回复 {{replyTarget.nickname || '球友'}}</text>
        <view class="reply-close" bindtap="cancelReply">×</view>
      </view>
      <textarea class="comment-input" value="{{replyContent}}" placeholder="写下回复" maxlength="300" bindinput="onReplyInput"></textarea>
      <button class="primary-btn" loading="{{submitting}}" bindtap="submitReply">发表回复</button>
    </view>

    <view class="comment-header">
      <text>评论区：</text>
      <view class="comment-tools">
        <text class="comment-count">▣ {{detail.commentCount || comments.length || 0}}</text>
      </view>
    </view>
    <view wx:if="{{comments.length}}" class="comments">
      <view wx:for="{{comments}}" wx:key="id" class="comment-item">
        <view class="comment-head">
          <image wx:if="{{item.avatarUrl}}" class="comment-avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>
          <view wx:else class="comment-avatar avatar-placeholder">羽</view>
          <view class="comment-main">
            <view class="comment-name-row">
              <text>{{item.nickname || '球友'}}</text>
              <view class="reply-action" bindtap="startReply" data-comment="{{item}}">↩</view>
            </view>
            <view class="comment-content">{{item.content}}</view>
          </view>
        </view>
        <view wx:if="{{item.replies && item.replies.length}}" class="reply-list">
          <view wx:for="{{item.replies}}" wx:key="id" class="reply-item">
            <text class="reply-name">{{item.nickname || '球友'}}：</text>{{item.content}}
          </view>
        </view>
      </view>
    </view>
    <view wx:else class="empty-comments">暂无评论</view>
  </view>

  <view wx:if="{{!loading && !error}}" class="comment-toolbar">
    <view class="toolbar-comment">▣</view>
    <input class="toolbar-input" value="{{commentContent}}" placeholder="不要忘记友善评论哦！" confirm-type="send" bindinput="onCommentInput" bindconfirm="submitComment" />
    <view class="toolbar-send" bindtap="submitComment">↗</view>
    <view class="toolbar-action like-action {{detail.liked ? 'active' : ''}}" bindtap="onLike">{{detail.liked ? '♥' : '♡'}}</view>
    <view class="toolbar-action favorite-action {{detail.favorited ? 'active' : ''}}" bindtap="onFavorite">{{detail.favorited ? '★' : '☆'}}</view>
  </view>

  <auth-popup visible="{{showAuth}}" bind:cancel="hideAuth" bind:success="afterLogin"></auth-popup>
</view>
