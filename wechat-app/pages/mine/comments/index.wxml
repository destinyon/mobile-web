<view class="page-shell">
  <view class="brand-strip">
    <view class="back" bindtap="goBack">‹</view>
    <text class="brand-title-mini">我的评论</text>
  </view>
  <view class="section-title">我的评论</view>
  <view wx:if="{{loading}}" class="state-box">正在加载...</view>
  <view wx:elif="{{error}}" class="state-box" bindtap="load">{{error}}，点击重试</view>
  <view wx:elif="{{!items.length}}" class="state-box">还没有评论记录</view>
  <view wx:else class="comment-list">
    <view wx:for="{{items}}" wx:key="id" class="comment-card" bindtap="goTarget" data-item="{{item}}">
      <view class="target-row">
        <image wx:if="{{item.targetCoverUrl}}" class="target-cover" src="{{item.targetCoverUrl}}" mode="aspectFill"></image>
        <view class="target-main">
          <view class="comment-title">{{item.targetTitle || '内容已不可见'}}</view>
          <view class="muted">{{item.targetType === 'POST' ? '帖子' : '新闻'}} · {{item.targetOwnerName || '羽球在线'}}</view>
        </view>
      </view>
      <view wx:if="{{item.parentContent}}" class="parent-content">回复：{{item.parentContent}}</view>
      <view class="comment-content">{{item.content}}</view>
      <view class="muted">{{item.createdAt || ''}}</view>
    </view>
  </view>
  <auth-popup visible="{{showAuth}}" bind:cancel="hideAuth" bind:success="afterLogin"></auth-popup>
</view>
