.post-card {
  display: flex;
  gap: 16rpx;
  padding: 16rpx;
  border: 2rpx solid #172117;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 6rpx 6rpx 0 rgba(23, 33, 23, 0.16);
}

.cover {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 176rpx;
  width: 176rpx;
  height: 136rpx;
  border: 2rpx solid #172117;
  border-radius: 6rpx;
  background: #e7f6d8;
}

.cover-placeholder {
  color: #172117;
  font-size: 46rpx;
  font-weight: 900;
}

.post-body {
  flex: 1;
  min-width: 0;
}

.post-head,
.meta {
  display: flex;
  align-items: center;
  gap: 18rpx;
  color: #65705f;
  font-size: 23rpx;
}

.topic {
  padding: 4rpx 10rpx;
  border: 2rpx solid #172117;
  border-radius: 6rpx;
  background: #baf279;
  color: #172117;
  font-weight: 800;
  font-size: 21rpx;
}

.status {
  margin-left: auto;
}

.title {
  margin-top: 10rpx;
  color: #172117;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.35;
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.meta {
  gap: 8rpx 14rpx;
  margin-top: 12rpx;
  flex-wrap: wrap;
  font-size: 21rpx;
}
