.brand-strip {
  display: flex;
  align-items: center;
  height: 64rpx;
  margin-bottom: 14rpx;
  border: 2rpx solid #172117;
  background: #fafff3;
}

.back {
  width: 62rpx;
  text-align: center;
  font-size: 44rpx;
  line-height: 1;
}

.brand-title-mini {
  flex: 1;
  padding-right: 62rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 800;
}

.article {
  padding: 18rpx;
  border: 2rpx solid #172117;
  border-radius: 6rpx;
  background: #ffffff;
}

.title {
  color: #172117;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.35;
}

.meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 22rpx;
  margin: 14rpx 0 16rpx;
  color: #65705f;
  font-size: 24rpx;
}

.cover {
  width: 100%;
  height: 330rpx;
  margin: 8rpx 0 18rpx;
  border: 2rpx solid #172117;
  border-radius: 6rpx;
  background: #dff5c9;
}

.content {
  color: #283227;
  font-size: 29rpx;
  line-height: 1.75;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 14rpx;
}

.action-btn {
  min-height: 68rpx;
  border: 2rpx solid #172117;
  border-radius: 6rpx;
  background: #ffffff;
  color: #172117;
  font-size: 28rpx;
  font-weight: 800;
}

.comment-box {
  margin-top: 16rpx;
  padding: 16rpx;
  border: 2rpx solid #172117;
  border-radius: 6rpx;
  background: #ffffff;
}

.comment-input {
  width: 100%;
  min-height: 150rpx;
  padding: 18rpx;
  border: 2rpx solid #d6dfcf;
  border-radius: 6rpx;
  font-size: 28rpx;
}

.comment-box .primary-btn {
  margin-top: 18rpx;
}

.comments {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.comment-item {
  padding: 18rpx;
  border: 2rpx solid #172117;
  border-radius: 6rpx;
  background: #ffffff;
}

.comment-head {
  color: #172117;
  font-size: 26rpx;
  font-weight: 800;
}

.comment-content {
  margin-top: 10rpx;
  color: #3d493a;
  font-size: 27rpx;
  line-height: 1.6;
}
