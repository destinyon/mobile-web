<view class="page-shell mine-shell">
  <view class="brand-bar mine-brand">
    <view class="brand-title"><text class="brand-mark">羽</text>羽球在线</view>
  </view>

  <view class="profile card">
    <image wx:if="{{profile.avatarUrl || profile.avatar}}" class="avatar" src="{{profile.avatarUrl || profile.avatar}}" mode="aspectFill"></image>
    <view wx:else class="avatar avatar-placeholder">羽</view>
    <view class="profile-main">
      <view class="name">{{profile.nickname || profile.nickName || '未登录球友'}}</view>
      <view class="muted">{{profile.bio || profile.mobile || '登录后查看收藏、评论和发布记录'}}</view>
    </view>
    <button class="login-mini" bindtap="ensureLogin">{{profile.id ? '已登录' : '登录'}}</button>
  </view>

  <view class="section-title">常用功能：</view>
  <view class="tool-list">
    <view class="tool-item" bindtap="goPage" data-url="/pages/mine/favorites/index">
      <view class="tool-icon">★</view>
      <view class="tool-text">我的收藏</view>
      <view class="tool-arrow">›</view>
    </view>
    <view class="tool-item" bindtap="goPage" data-url="/pages/mine/comments/index">
      <view class="tool-icon">评</view>
      <view class="tool-text">我的评论</view>
      <view class="tool-arrow">›</view>
    </view>
    <view class="tool-item" bindtap="goPage" data-url="/pages/mine/posts/index">
      <view class="tool-icon">稿</view>
      <view class="tool-text">我的发布</view>
      <view class="tool-arrow">›</view>
    </view>
    <view class="tool-item" bindtap="goPage" data-url="/pages/news/editor/index">
      <view class="tool-icon">＋</view>
      <view class="tool-text">发布内容</view>
      <view class="tool-arrow">›</view>
    </view>
  </view>

  <view wx:if="{{error}}" class="state-box" bindtap="loadProfile">{{error}}，点击重试</view>
  <auth-popup visible="{{showAuth}}" bind:cancel="hideAuth" bind:success="afterLogin"></auth-popup>
</view>
