<view class="page-shell profile-edit-shell">
  <view class="brand-strip">
    <view class="back" bindtap="goBack">‹</view>
    <text class="brand-title-mini">个人资料</text>
  </view>

  <view wx:if="{{loading}}" class="state-box">正在加载资料...</view>
  <view wx:else class="profile-form card">
    <button class="avatar-edit" loading="{{uploading}}" bindtap="chooseAvatar">
      <view class="avatar-frame">
        <image wx:if="{{form.avatarUrl}}" src="{{form.avatarUrl}}" mode="aspectFill"></image>
        <view wx:else class="avatar-placeholder">羽</view>
      </view>
      <view class="avatar-mark">✎</view>
    </button>

    <view class="field-label">昵称</view>
    <input class="field" value="{{form.nickname}}" maxlength="80" placeholder="填写昵称" bindinput="onField" data-key="nickname" />

    <view class="field-label">手机号</view>
    <input class="field" value="{{form.phone}}" maxlength="40" placeholder="可选" bindinput="onField" data-key="phone" />

    <view class="field-grid">
      <view>
        <view class="field-label">年龄</view>
        <picker mode="selector" range="{{ageOptions}}" data-key="age" data-options="ageOptions" bindchange="onPickerChange">
          <view class="field select-field">{{form.age ? form.age + ' 岁' : '请选择'}}</view>
        </picker>
      </view>
      <view>
        <view class="field-label">球龄</view>
        <picker mode="selector" range="{{playYearOptions}}" data-key="playYears" data-options="playYearOptions" bindchange="onPickerChange">
          <view class="field select-field">{{form.playYears !== '' ? form.playYears + ' 年' : '请选择'}}</view>
        </picker>
      </view>
    </view>

    <view class="field-label">性别</view>
    <picker mode="selector" range="{{genderOptions}}" data-key="gender" data-options="genderOptions" bindchange="onPickerChange">
      <view class="field select-field">{{form.gender || '请选择'}}</view>
    </picker>

    <button class="primary-btn" loading="{{saving}}" bindtap="save">保存资料</button>
  </view>
  <auth-popup visible="{{showAuth}}" bind:cancel="hideAuth" bind:success="afterLogin"></auth-popup>
</view>
